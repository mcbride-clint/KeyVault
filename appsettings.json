{
  "ConnectionStrings": {
    "Oracle": "User Id=kvs_owner;Password=CHANGEME;Data Source=your-oracle-host:1521/ORCL"
  },
  "Encryption": {
    // Mode: "DPAPI" (default, single-machine, Windows only) or "AesKeyWrap" (multi-instance, cross-machine)
    "Mode": "DPAPI",
    // MasterKey: required when Mode is "AesKeyWrap". Base64-encoded 32-byte key.
    // Generate with: openssl rand -base64 32
    // NEVER commit the real value — set via environment variable: Encryption__MasterKey
    "MasterKey": ""
  },
  "Authorization": {
    "AdminGroup": "KeyVaultAdmins",
    "AdminUsers":  []
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/keyvault-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
