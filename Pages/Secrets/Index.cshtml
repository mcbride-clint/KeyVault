@page
@model KeyVaultService.Pages.Secrets.IndexModel
@{
    ViewData["Title"]      = "Secrets";
    ViewData["ActivePage"] = "Secrets";
}

<div class="flex-row mt-0" style="margin-bottom:20px">
    <div class="spacer"></div>
    <button class="btn btn-primary" onclick="openModal('createModal')">+ New Secret</button>
</div>

<div class="card">
    <div class="card-header">
        <span>@Model.Secrets.Count() secrets</span>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Description</th>
                <th>Last Updated</th>
                <th>Created By</th>
                <th>Grants</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Secrets)
            {
                <tr>
                    <td class="text-mono" style="font-weight:500">@s.Name</td>
                    <td><span class="badge @TypeBadge(s.Type)">@s.Type</span></td>
                    <td class="text-dim">@s.Description</td>
                    <td class="text-mono text-dim" style="font-size:12px">@s.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-dim" style="font-size:12px">@s.CreatedBy</td>
                    <td class="text-mono">@s.Grants.Count</td>
                    <td>
                        <div class="flex-row">
                            <button class="btn btn-secondary btn-sm" onclick="revealSecret(@s.Id, '@s.Name')">Reveal</button>
                            <a asp-page="/Grants/Index" asp-route-secretId="@s.Id" class="btn btn-secondary btn-sm">Grants</a>
                            <button class="btn btn-secondary btn-sm" onclick="openEditModal(@s.Id, '@s.Name', '@s.Type', '@(s.Description ?? "")')">Edit</button>
                            <button class="btn btn-danger btn-sm" onclick="confirmDelete(@s.Id, '@s.Name')">Delete</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Create Modal -->
<div class="modal-overlay" id="createModal">
    <div class="modal">
        <div class="modal-title">New Secret</div>
        <form method="post" asp-page-handler="Create">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Name *</label>
                    <input name="name" class="form-control form-control-mono" placeholder="e.g. prod-db-password" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Type</label>
                    <select name="type" class="form-control">
                        @foreach (var t in Enum.GetNames<KeyVaultService.Models.SecretType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <input name="description" class="form-control" placeholder="Optional note" />
                </div>
                <div class="form-group">
                    <label class="form-label">Value *</label>
                    <textarea name="value" class="form-control form-control-mono" rows="3" required></textarea>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('createModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Create Secret</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="editModal">
    <div class="modal">
        <div class="modal-title">Update Secret Value</div>
        <form method="post" asp-page-handler="UpdateValue">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editId" name="id" />
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Secret</label>
                    <input id="editName" class="form-control form-control-mono" disabled />
                </div>
                <div class="form-group">
                    <label class="form-label">New Value *</label>
                    <textarea name="value" class="form-control form-control-mono" rows="3" required></textarea>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save New Value</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal">
        <div class="modal-title">Confirm Delete</div>
        <p style="color:var(--text-dim);margin-bottom:8px">This will deactivate the secret:</p>
        <p id="deleteSecretName" class="text-mono" style="color:var(--danger)"></p>
        <form method="post" asp-page-handler="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteId" name="id" />
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
                <button type="submit" class="btn btn-danger">Deactivate</button>
            </div>
        </form>
    </div>
</div>

<!-- Reveal Modal -->
<div class="modal-overlay" id="revealModal">
    <div class="modal">
        <div class="modal-title" id="revealTitle">Secret Value</div>
        <div id="revealContent" class="secret-reveal" style="display:block">Loading…</div>
        <div class="modal-actions">
            <button class="btn btn-secondary" onclick="closeModal('revealModal')">Close</button>
        </div>
    </div>
</div>

@functions {
    string TypeBadge(KeyVaultService.Models.SecretType t) => t switch {
        KeyVaultService.Models.SecretType.Password         => "badge-red",
        KeyVaultService.Models.SecretType.ConnectionString => "badge-blue",
        KeyVaultService.Models.SecretType.ApiKey           => "badge-yellow",
        _                                                  => "badge-dim"
    };
}

@section Scripts {
<script>
function revealSecret(id, name) {
    document.getElementById('revealTitle').textContent = 'Secret: ' + name;
    document.getElementById('revealContent').textContent = 'Loading…';
    openModal('revealModal');
    fetch('/api/secrets/' + encodeURIComponent(name))
        .then(r => r.ok ? r.json() : Promise.reject(r.status))
        .then(d => { document.getElementById('revealContent').textContent = d.value; })
        .catch(e => { document.getElementById('revealContent').textContent = 'Error: ' + e; });
}
function openEditModal(id, name, type, desc) {
    document.getElementById('editId').value   = id;
    document.getElementById('editName').value = name;
    openModal('editModal');
}
function confirmDelete(id, name) {
    document.getElementById('deleteId').value             = id;
    document.getElementById('deleteSecretName').textContent = name;
    openModal('deleteModal');
}
</script>
}
